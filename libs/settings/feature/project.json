{
  "name": "settings-feature",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["scope:settings", "type:feature"],
  "sourceRoot": "libs/settings/feature/src",
  "prefix": "app",
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/settings/feature/**/*.ts", "libs/settings/feature/**/*.html"]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "libs/settings/feature/vite.config.ts",
        "reportsDirectory": "coverage/libs/settings/feature",
        "passWithNoTests": true
      }
    }
  }
}
