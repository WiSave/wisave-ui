{
  "name": "platform-auth",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["scope:platform", "type:auth"],
  "sourceRoot": "libs/platform/auth/src",
  "prefix": "app",
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/platform/auth/**/*.ts", "libs/platform/auth/**/*.html"]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "libs/platform/auth/vite.config.ts",
        "reportsDirectory": "coverage/libs/platform/auth",
        "passWithNoTests": true
      }
    }
  }
}
