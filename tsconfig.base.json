{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "@features/*": ["./apps/wisave-ui/src/app/features/*"],
      "@services/*": ["./apps/wisave-ui/src/app/core/services/*"],
      "@wisave/platform/auth": ["./libs/platform/auth/src/index.ts"],
      "@wisave/platform/config": ["./libs/platform/config/src/index.ts"],
      "@wisave/platform/shell": ["./libs/platform/shell/src/index.ts"],
      "@wisave/platform/signalr": ["./libs/platform/signalr/src/index.ts"],
      "@wisave/shared/model": ["./libs/shared/model/src/index.ts"],
      "@wisave/shared/ui": ["./libs/shared/ui/src/index.ts"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2024",
    "module": "preserve",
    "rootDir": "."
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "exclude": ["node_modules", "tmp"]
}
